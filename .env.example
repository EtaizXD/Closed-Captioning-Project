# Copy to ``.env`` and adjust for your environment.
# The Flask app loads these via os.environ; sentence_recognition.py is
# launched as a subprocess and inherits the same environment.

# --- Whisper backend selection ---------------------------------------------
# local  = load faster-whisper in-process (default; requires
#          requirements-local.txt to be installed)
# remote = call the FastAPI service in ./server (set this once the GPU
#          server is ready and reachable)
WHISPER_BACKEND=local

# --- Local backend settings (used when WHISPER_BACKEND=local) --------------
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# WHISPER_MIN_AVAILABLE_GB=8

# --- Remote backend settings (used when WHISPER_BACKEND=remote) ------------
# URL of the FastAPI service. Use http://localhost:8000 while you smoke
# test the service on your own machine, then switch to the GPU server's
# IP (e.g. http://10.80.39.41:8000) once the container is deployed there.
WHISPER_API_URL=http://localhost:8000

# Shared-secret API key. Must match the WHISPER_API_KEY env var passed
# to the FastAPI container (`docker run -e WHISPER_API_KEY=...`). Leave
# blank on both sides to disable auth.
WHISPER_API_KEY=

# Request timeout in seconds (the model takes a while on long audio).
WHISPER_API_TIMEOUT=600

# Language hint sent to the API (ISO 639-1, e.g. ``en``, ``th``).
WHISPER_LANGUAGE=en
